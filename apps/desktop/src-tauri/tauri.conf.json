{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Fixly",
  "version": "1.0.0",
  "identifier": "com.fixly.desktop",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fixly",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000 http://localhost:8000; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "publisher": "Aryan Sonsurkar",
    "copyright": "Copyright (c) 2026 Aryan Sonsurkar. All rights reserved.",
    "shortDescription": "Fixly - AI-powered academic operating system",
    "longDescription": "Fixly is an AI-powered academic operating system that helps students manage their study sessions, assignments, and academic workflow with intelligent scheduling, note-taking, and productivity tools.",
    "license": "../LICENSE",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "installerHeaderIcon": "icons/icon.ico"
      },
      "wix": {
        "language": "en-US",
        "template": "fragment"
      }
    }
  }
}
