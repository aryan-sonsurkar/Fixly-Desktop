# --- Backend ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
GEMINI_API_KEY=your_gemini_api_key
OLLAMA_HOST=http://localhost:11434
ENVIRONMENT=development

# Feature Flags (backend, prefix: FEATURE_)
FEATURE_ENABLE_OLLAMA=true
FEATURE_ENABLE_GEMINI=false
FEATURE_ENABLE_EMAIL_INTELLIGENCE=false
FEATURE_ENABLE_OCR=false
FEATURE_ENABLE_AUTO_UPDATER=true
FEATURE_ENABLE_EXPERIMENTAL=false

# --- Frontend ---
VITE_API_URL=http://localhost:8000
VITE_FEATURE_GEMINI=false
VITE_FEATURE_EMAIL_INTELLIGENCE=false
VITE_FEATURE_OCR=false
VITE_FEATURE_EXPERIMENTAL=false
